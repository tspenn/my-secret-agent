# ─── Supabase (shared project — same as FRIDAY Canvas, GoShop, GoTRVL, LnkLokr) ─
# Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ─── VAPID public key for Web Push notifications ──────────────────────────────
# Same key used by all sister apps (FRIDAY Canvas, GoShop, etc.) since it's
# tied to the project. Get it from any sister app's .env or push code.
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ─── App Mode ─────────────────────────────────────────────────────────────────
# Controls which UI ships:
#   secret_agent → my-secret-agent.com (Entry tier, sentence form default,
#                  4-mission limit, 10-day free trial → $4.99/mo)
#   gia          → go-i-agency.com    (upgrade product, Command Center default,
#                  unlimited missions, $14.99/mo or $29.99/mo)
VITE_APP_MODE=secret_agent

# ─── Supabase Edge Function secrets (already set in shared project — do not recreate)
# WEB-PUSH_PUBLIC_KEY    ← already exists
# WEB_PUSH_PRIVATE_KEY   ← already exists
# WEB_PUSH_CONTACT-EMAIL ← already exists
