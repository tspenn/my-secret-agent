# ─── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ─── VAPID public key for Web Push notifications ──────────────────────────────
# Must match WEB_PUSH_PUBLIC_KEY_MY_SECRET_AGENT set in Edge Function secrets.
# Generate a new key pair: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY_MY_SECRET_AGENT=your_vapid_public_key_here

# ─── Supabase Edge Function secrets ───────────────────────────────────────────
# Set these in: Dashboard → Edge Functions → mission-watcher → Secrets
# (never commit real values here)
#
# Naming convention: all secrets are app-suffixed because this Supabase project
# is shared across multiple Skyland apps (FRIDAY, GoNews, GoShop, My Money, etc.)
#
# WEB_PUSH_PUBLIC_KEY_MY_SECRET_AGENT    ← VAPID public key
# WEB_PUSH_PRIVATE_KEY_MY_SECRET_AGENT   ← VAPID private key
# WEB_PUSH_CONTACT_EMAIL_MY_SECRET_AGENT ← mailto:you@yourdomain.com
# CURRENTS_API_KEY                       ← https://currentsapi.services (for news_keyword missions)
#
# ─── Twilio SMS (Agency tier) ─────────────────────────────────────────────────
# Set via: supabase secrets set TWILIO_ACCOUNT_SID=... --project-ref psbdjnqcjpxapypcfigx
#
# TWILIO_ACCOUNT_SID   ← Twilio console → Account SID (AC...)
# TWILIO_API_KEY       ← Twilio console → API Keys → Key SID (SK...)
# TWILIO_API_SECRET    ← Twilio console → API Keys → secret
# TWILIO_FROM_NUMBER   ← Your Twilio number, e.g. +17175275505
#
# ─── Resend (weekly digest — Agency tier only, Sunday nights) ─────────────────
# Sign up free at resend.com — 3,000 emails/month included
# Verify your sending domain first: resend.com → Domains
#
# RESEND_API_KEY        ← resend.com → API Keys
# DIGEST_FROM_EMAIL     ← e.g. agent@my-secret-agent.com (must match verified domain)
